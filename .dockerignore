# Build context exclusions.
#
# Keep the build context lean: smaller context = faster `docker build`,
# avoids accidentally baking secrets or local-only state into the image.
# Anything not listed here is sent to the Docker daemon.

# Version control
.git/
.gitignore

# Python build / runtime caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
venv/
.venv/
env/

# MLflow tracking (regenerated by training; not needed in image)
mlruns/
mlartifacts/

# Raw data (artifacts/model.joblib carries the trained model;
# raw data is a training-time concern, not runtime)
data/

# Tests + dev tooling
tests/
.coverage
htmlcov/

# Agent / IDE artifacts
.claude/
.vscode/
.idea/
*.swp

# Documentation not needed in build context.
# README.md is NOT excluded — pyproject.toml's `readme = "README.md"`
# field requires it to be present at `pip install` time.
dsm-docs/
_reference/
CHANGELOG.md

# OS
.DS_Store
Thumbs.db

# Docker
Dockerfile
.dockerignore
